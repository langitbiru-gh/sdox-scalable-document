{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sdox.dev/ast-spec.json",
  "title": "SDOX AST Specification",
  "version": "0.3.0",
  "type": "object",
  "$ref": "#/definitions/DocumentNode",
  "definitions": {
    "Position": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": { "$ref": "#/definitions/Point" },
        "end": { "$ref": "#/definitions/Point" }
      }
    },
    "Point": {
      "type": "object",
      "required": ["line", "column"],
      "properties": {
        "line": { "type": "integer" },
        "column": { "type": "integer" },
        "offset": { "type": "integer" }
      }
    },
    "AttributeValue": { "oneOf": [{ "type": "string" }, { "type": "number" }, { "type": "boolean" }] },
    "BaseNode": {
      "type": "object",
      "required": ["type", "position"],
      "properties": {
        "type": { "type": "string" },
        "attributes": { "type": "object", "additionalProperties": { "$ref": "#/definitions/AttributeValue" } },
        "content": { "type": ["string", "null"] },
        "children": { "type": "array", "items": { "$ref": "#/definitions/AnyNode" } },
        "position": { "$ref": "#/definitions/Position" }
      }
    },
    "AnyNode": {
      "oneOf": [
        { "$ref": "#/definitions/DocumentNode" },
        { "$ref": "#/definitions/TitleNode" },
        { "$ref": "#/definitions/ParagraphNode" },
        { "$ref": "#/definitions/SectionNode" },
        { "$ref": "#/definitions/DividerNode" },
        { "$ref": "#/definitions/TextNode" },
        { "$ref": "#/definitions/QuoteNode" },
        { "$ref": "#/definitions/NoteNode" },
        { "$ref": "#/definitions/PlainTextNode" },
        { "$ref": "#/definitions/ListNode" },
        { "$ref": "#/definitions/ItemNode" },
        { "$ref": "#/definitions/UrlNode" },
        { "$ref": "#/definitions/ImageNode" },
        { "$ref": "#/definitions/CodeNode" },
        { "$ref": "#/definitions/OutputNode" },
        { "$ref": "#/definitions/TableNode" },
        { "$ref": "#/definitions/RowNode" },
        { "$ref": "#/definitions/CellNode" },
        { "$ref": "#/definitions/CardNode" },
        { "$ref": "#/definitions/TabNode" },
        { "$ref": "#/definitions/AccordionNode" },
        { "$ref": "#/definitions/IncludeNode" },
        { "$ref": "#/definitions/TemplateNode" },
        { "$ref": "#/definitions/UseNode" },
        { "$ref": "#/definitions/MetadataNode" },
        { "$ref": "#/definitions/DatasetNode" },
        { "$ref": "#/definitions/ExampleNode" },
        { "$ref": "#/definitions/InstructionNode" },
        { "$ref": "#/definitions/ResponseNode" },
        { "$ref": "#/definitions/EmbeddingNode" },
        { "$ref": "#/definitions/ChunkNode" },
        { "$ref": "#/definitions/ContextNode" },
        { "$ref": "#/definitions/CompletionNode" },
        { "$ref": "#/definitions/ChartNode" },
        { "$ref": "#/definitions/DataNode" },
        { "$ref": "#/definitions/MathNode" },
        { "$ref": "#/definitions/DiagramNode" },
        { "$ref": "#/definitions/TimelineNode" },
        { "$ref": "#/definitions/EventNode" },
        { "$ref": "#/definitions/TocNode" },
        { "$ref": "#/definitions/RefNode" },
        { "$ref": "#/definitions/FootnoteNode" },
        { "$ref": "#/definitions/GridNode" },
        { "$ref": "#/definitions/ColumnNode" },
        { "$ref": "#/definitions/VideoNode" },
        { "$ref": "#/definitions/BadgeNode" },
        { "$ref": "#/definitions/TermNode" },
        { "$ref": "#/definitions/DefinitionNode" },
        { "$ref": "#/definitions/ChangelogNode" },
        { "$ref": "#/definitions/QuestionNode" },
        { "$ref": "#/definitions/OptionNode" },
        { "$ref": "#/definitions/ExplanationNode" },
        { "$ref": "#/definitions/FlashcardNode" },
        { "$ref": "#/definitions/FrontNode" },
        { "$ref": "#/definitions/BackNode" },
        { "$ref": "#/definitions/StepperNode" },
        { "$ref": "#/definitions/StepNode" },
        { "$ref": "#/definitions/PollNode" },
        { "$ref": "#/definitions/ChoiceNode" },
        { "$ref": "#/definitions/RandomPickerNode" },
        { "$ref": "#/definitions/PickerOptionNode" }
      ]
    },
    "DocumentNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "document" } } },
    "TitleNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "title" } } },
    "ParagraphNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "paragraph" } } },
    "SectionNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "section" } } },
    "DividerNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "divider" } } },
    "TextNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "text" } } },
    "PlainTextNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "plain_text" } } },
    "QuoteNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "quote" } } },
    "NoteNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "note" } } },
    "ListNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "list" } } },
    "ItemNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "item" } } },
    "UrlNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "url" } } },
    "ImageNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "image" } } },
    "CodeNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "code" } } },
    "OutputNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "output" } } },
    "TableNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "table" } } },
    "RowNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "row" } } },
    "CellNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "cell" } } },
    "CardNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "card" } } },
    "TabNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "tab" } } },
    "AccordionNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "accordion" } } },
    "IncludeNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "include" } } },
    "TemplateNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "template" } } },
    "UseNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "use" } } },
    "MetadataNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "metadata" } } },
    "DatasetNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "dataset" } } },
    "ExampleNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "example" } } },
    "InstructionNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "instruction" } } },
    "ResponseNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "response" } } },
    "EmbeddingNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "embedding" } } },
    "ChunkNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "chunk" } } },
    "ContextNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "context" } } },
    "CompletionNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "completion" } } },
    "ChartNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "chart" } } },
    "DataNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "data" } } },
    "MathNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "math" } } },
    "DiagramNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "diagram" } } },
    "TimelineNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "timeline" } } },
    "EventNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "event" } } },
    "TocNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "toc" } } },
    "RefNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "ref" } } },
    "FootnoteNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "footnote" } } },
    "GridNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "grid" } } },
    "ColumnNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "column" } } },
    "VideoNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "video" } } },
    "BadgeNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "badge" } } },
    "TermNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "term" } } },
    "DefinitionNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "definition" } } },
    "ChangelogNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "changelog" } } },
    "QuestionNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "question" } } },
    "OptionNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "option" } } },
    "ExplanationNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "explanation" } } },
    "FlashcardNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "flashcard" } } },
    "FrontNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "front" } } },
    "BackNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "back" } } },
    "StepperNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "stepper" } } },
    "StepNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "step" } } },
    "PollNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "poll" } } },
    "ChoiceNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "choice" } } },
    "RandomPickerNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "random-picker" } } },
    "PickerOptionNode": { "allOf": [{ "$ref": "#/definitions/BaseNode" }], "properties": { "type": { "const": "picker-option" } } }
  }
}
