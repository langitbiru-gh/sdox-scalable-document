#title(level=1) SDOX Full Example

#paragraph {
  This document demonstrates every tag category
  in the Scalable Document specification.
}

#divider

#section(title="Text & Semantics", id="text") {

  #paragraph {
    You can use #text(style="bold") bold text and
    #text(style="italic") italic text inline.
  }

  #quote(author="Alan Turing") {
    We can only see a short distance ahead,
    but we can see plenty there that needs to be done.
  }

  #note(type="warning") {
    Never expose API keys in client-side code.
  }

  #note(type="success") {
    All tests passed successfully.
  }
}

