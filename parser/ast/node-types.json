{
  "$schema": "https://sdox.dev/ast-spec.json",
  "version": "0.1.0",
  "description": "Quick reference of all SDOX AST node types. Use ast-spec.json for formal validation.",

  "node_types": [
    {
      "type": "document",
      "category": "root",
      "description": "Root node of every AST",
      "has_content": false,
      "has_children": true,
      "allowed_children": ["*"],
      "required_attributes": [],
      "optional_attributes": [],
      "notes": "Always the top-level node. Only one per AST."
    },
    {
      "type": "title",
      "category": "structure",
      "description": "Heading element",
      "has_content": true,
      "has_children": false,
      "allowed_children": [],
      "required_attributes": [
        { "name": "level", "type": "integer", "range": "1-6" }
      ],
      "optional_attributes": [
        { "name": "id", "type": "string" }
      ],
      "form": "inline"
    },
    {
      "type": "paragraph",
      "category": "structure",
      "description": "Block of body text",
      "has_content": true,
      "has_children": true,
      "allowed_children": ["text", "url", "plain_text"],
      "required_attributes": [],
      "optional_attributes": [],
      "form": "block",
      "notes": "Content is plain string for simple paragraphs. Children are used for mixed inline content."
    },
    {
      "type": "section",
      "category": "structure",
      "description": "Named content group",
      "has_content": false,
      "has_children": true,
      "allowed_children": ["*"],
      "required_attributes": [],
      "optional_attributes": [
        { "name": "title", "type": "string" },
        { "name": "id", "type": "string" }
      ],
      "form": "block"
    },
    {
      "type": "divider",
      "category": "structure",
      "description": "Horizontal rule",
      "has_content": false,
      "has_children": false,
      "allowed_children": [],
      "required_attributes": [],
      "optional_attributes": [],
      "form": "inline"
    },
    {
      "type": "text",
      "category": "text",
      "description": "Inline styled text",
      "has_content": true,
      "has_children": false,
      "allowed_children": [],
      "required_attributes": [],
      "optional_attributes": [
        { "name": "style", "type": "enum", "values": ["bold", "italic", "strikethrough", "underline"] },
        { "name": "color", "type": "string" },
        { "name": "size", "type": "string" }
      ],
      "form": "inline"
    },
    {
      "type": "plain_text",
      "category": "text",
      "description": "Untagged plain text content",
      "has_content": true,
      "has_children": false,
      "allowed_children": [],
      "required_attributes": [],
      "optional_attributes": [],
      "form": "implicit",
      "notes": "Generated by the parser for text outside tags within a block. Not directly authored."
    },
    {
      "type": "quote",
      "category": "text",
      "description": "Blockquote with optional attribution",
      "has_content": true,
      "has_children": true,
      "allowed_children": ["*"],
      "required_attributes": [],
      "optional_attributes": [
        { "name": "author", "type": "string" }
      ],
      "form": "block"
    },
    {
      "type": "note",
      "category": "text",
      "description": "Callout box with severity",
      "has_content": true,
      "has_children": true,
      "allowed_children": ["*"],
      "required_attributes": [
        { "name": "type", "type": "enum", "values": ["info", "warning", "danger", "success"] }
      ],
      "optional_attributes": [],
      "form": "block"
    },
    {
      "type": "list",
      "category": "list",
      "description": "List container",
      "has_content": false,
      "has_children": true,
      "allowed_children": ["item"],
      "required_attributes": [],
      "optional_attributes": [
        { "name": "type", "type": "enum", "values": ["unordered", "ordered", "checklist"], "default": "unordered" }
      ],
      "form": "block"
    },
    {
      "type": "item",
      "category": "list",
      "description": "Single list item",
      "has_content": true,
      "has_children": true,
      "allowed_children": ["*"],
      "required_attributes": [],
      "optional_attributes": [
        { "name": "done", "type": "boolean", "default": false },
        { "name": "key", "type": "string" }
      ],
      "form": "both",
      "notes": "key attribute is used for metadata items."
    },
    {
      "type": "url",
      "category": "link",
      "description": "Hyperlink",
      "has_content": true,
      "has_children": false,
      "allowed_children": [],
      "required_attributes": [
        { "name": "href", "type": "string" }
      ],
      "optional_attributes": [
        { "name": "title", "type": "string" },
        { "name": "target", "type": "enum", "values": ["_self", "_blank"] }
      ],
      "form": "inline"
    },
    {
      "type": "image",
      "category": "link",
      "description": "Image element",
      "has_content": false,
      "has_children": false,
      "allowed_children": [],
      "required_attributes": [
        { "name": "src", "type": "string" },
        { "name": "alt", "type": "string" }
      ],
      "optional_attributes": [
        { "name": "width", "type": "number" },
        { "name": "height", "type": "number" }
      ],
      "form": "inline"
    },
    {
      "type": "code",
      "category": "code",
      "description": "Fenced code block",
      "has_content": true,
      "has_children": false,
      "allowed_children": [],
      "required_attributes": [],
      "optional_attributes": [
        { "name": "language", "type": "string" },
        { "name": "title", "type": "string" },
        { "name": "line_number", "type": "boolean", "default": false },
        { "name": "highlight", "type": "string" },
        { "name": "foldable", "type": "boolean", "default": false },
        { "name": "editable", "type": "boolean", "default": false },
        { "name": "runnable", "type": "boolean", "default": false },
        { "name": "theme", "type": "string" }
      ],
      "form": "block",
      "notes": "Content is raw code. Parser MUST preserve whitespace and indentation exactly."
    },
    {
      "type": "output",
      "category": "code",
      "description": "Command/API output",
      "has_content": true,
      "has_children": false,
      "allowed_children": [],
      "required_attributes": [],
      "optional_attributes": [
        { "name": "type", "type": "enum", "values": ["terminal", "json", "text", "html"] }
      ],
      "form": "block",
      "notes": "Content is preserved exactly."
    },
    {
      "type": "table",
      "category": "table",
      "description": "Data table container",
      "has_content": false,
      "has_children": true,
      "allowed_children": ["row"],
      "required_attributes": [],
      "optional_attributes": [],
      "form": "block"
    },
    {
      "type": "row",
      "category": "table",
      "description": "Table row",
      "has_content": false,
      "has_children": true,
      "allowed_children": ["cell"],
      "required_attributes": [],
      "optional_attributes": [],
      "form": "block"
    },
    {
      "type": "cell",
      "category": "table",
      "description": "Table cell",
      "has_content": true,
      "has_children": true,
      "allowed_children": ["*"],
      "required_attributes": [],
      "optional_attributes": [
        { "name": "header", "type": "boolean", "default": false }
      ],
      "form": "both"
    },
    {
      "type": "card",
      "category": "component",
      "description": "Contained content card",
      "has_content": false,
      "has_children": true,
      "allowed_children": ["*"],
      "required_attributes": [],
      "optional_attributes": [
        { "name": "title", "type": "string" },
        { "name": "type", "type": "string" }
      ],
      "form": "block"
    },
    {
      "type": "tab",
      "category": "component",
      "description": "Tab panel",
      "has_content": false,
      "has_children": true,
      "allowed_children": ["*"],
      "required_attributes": [
        { "name": "title", "type": "string" }
      ],
      "optional_attributes": [],
      "form": "block"
    },
    {
      "type": "accordion",
      "category": "component",
      "description": "Collapsible section",
      "has_content": false,
      "has_children": true,
      "allowed_children": ["*"],
      "required_attributes": [
        { "name": "title", "type": "string" }
      ],
      "optional_attributes": [],
      "form": "block"
    },
    {
      "type": "include",
      "category": "modularization",
      "description": "File inclusion directive",
      "has_content": false,
      "has_children": true,
      "allowed_children": ["*"],
      "required_attributes": [
        { "name": "src", "type": "string" }
      ],
      "optional_attributes": [],
      "form": "inline",
      "notes": "Children are empty before resolution. After file resolution, contains the included document's children."
    },
    {
      "type": "template",
      "category": "modularization",
      "description": "Reusable template definition",
      "has_content": false,
      "has_children": true,
      "allowed_children": ["*"],
      "required_attributes": [
        { "name": "name", "type": "string" }
      ],
      "optional_attributes": [],
      "form": "block"
    },
    {
      "type": "use",
      "category": "modularization",
      "description": "Template instantiation",
      "has_content": false,
      "has_children": true,
      "allowed_children": ["*"],
      "required_attributes": [
        { "name": "template", "type": "string" }
      ],
      "optional_attributes": [],
      "form": "inline",
      "notes": "Children are empty before resolution. After template resolution, contains the expanded template children."
    },
    {
      "type": "metadata",
      "category": "ai",
      "description": "Document-level metadata",
      "has_content": false,
      "has_children": true,
      "allowed_children": ["item"],
      "required_attributes": [],
      "optional_attributes": [],
      "form": "block"
    },
    {
      "type": "dataset",
      "category": "ai",
      "description": "Named dataset block",
      "has_content": false,
      "has_children": true,
      "allowed_children": ["*"],
      "required_attributes": [
        { "name": "name", "type": "string" }
      ],
      "optional_attributes": [],
      "form": "block"
    },
    {
      "type": "example",
      "category": "ai",
      "description": "AI few-shot example",
      "has_content": true,
      "has_children": true,
      "allowed_children": ["*"],
      "required_attributes": [],
      "optional_attributes": [
        { "name": "language", "type": "string" }
      ],
      "form": "block"
    },
    {
      "type": "instruction",
      "category": "ai",
      "description": "AI prompt instruction",
      "has_content": true,
      "has_children": true,
      "allowed_children": ["*"],
      "required_attributes": [],
      "optional_attributes": [
        { "name": "priority", "type": "enum", "values": ["low", "medium", "high"] }
      ],
      "form": "block"
    },
    {
      "type": "response",
      "category": "ai",
      "description": "AI response",
      "has_content": true,
      "has_children": true,
      "allowed_children": ["*"],
      "required_attributes": [],
      "optional_attributes": [
        { "name": "model", "type": "string" }
      ],
      "form": "block"
    },
    {
      "type": "embedding",
      "category": "ai",
      "description": "Vector embedding marker",
      "has_content": false,
      "has_children": false,
      "allowed_children": [],
      "required_attributes": [],
      "optional_attributes": [
        { "name": "model", "type": "string" }
      ],
      "form": "inline"
    },
    {
      "type": "chunk",
      "category": "ai",
      "description": "Content chunk for vector DB",
      "has_content": true,
      "has_children": true,
      "allowed_children": ["*"],
      "required_attributes": [],
      "optional_attributes": [
        { "name": "size", "type": "number" }
      ],
      "form": "block"
    },
    {
      "type": "context",
      "category": "ai",
      "description": "Scoped AI context",
      "has_content": true,
      "has_children": true,
      "allowed_children": ["*"],
      "required_attributes": [
        { "name": "scope", "type": "string" }
      ],
      "optional_attributes": [],
      "form": "block"
    },
    {
      "type": "completion",
      "category": "ai",
      "description": "AI auto-completion section",
      "has_content": true,
      "has_children": true,
      "allowed_children": ["*"],
      "required_attributes": [],
      "optional_attributes": [
        { "name": "model", "type": "string" }
      ],
      "form": "block"
    }
  ],

  "categories": [
    { "id": "root", "name": "Root" },
    { "id": "structure", "name": "Structure" },
    { "id": "text", "name": "Text & Semantics" },
    { "id": "list", "name": "Lists" },
    { "id": "link", "name": "Links & Media" },
    { "id": "code", "name": "Code" },
    { "id": "table", "name": "Tables" },
    { "id": "component", "name": "Components & Layout" },
    { "id": "modularization", "name": "Modularization" },
    { "id": "ai", "name": "AI-Native" }
  ],

  "forms": {
    "inline": "Tag and content on the same line: #tag(attrs) content",
    "block": "Multi-line content in curly braces: #tag(attrs) { ... }",
    "both": "Can be used in either inline or block form",
    "implicit": "Not authored directly, generated by the parser"
  }
}
