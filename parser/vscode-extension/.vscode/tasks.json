{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "compile",
      "command": "bunx",
      "args": ["tsc", "-p", "./"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "type": "shell",
      "label": "watch",
      "command": "bunx",
      "args": ["tsc", "-watch", "-p", "./"],
      "group": "build",
      "isBackground": true,
      "problemMatcher": ["$tsc-watch"]
    }
  ]
}
